{
  "type": "VStack",
  "properties": {
    "spacing": 10.0,
    "alignment": "center"
  },
  "children": [
    {
      "type": "Text",
      "properties": {
        "text": "KeyframeAnimator Variant"
      }
    },
    {
      "type": "KeyframeAnimator",
      "content": {
        "type": "Text",
        "properties": {
          "text": "Animating"
        }
      },
      "properties": {
        "initialValue": {
          "opacity": 0.0,
          "scale": 1.0,
          "rotation": 0.0
        },
        "trigger": "onAppear",
        "repeat": {
          "count": 3,
          "autoreverses": true
        },
        "delay": 1.0,
        "keyframes": {
          "0%": {
            "type": "linear",
            "value": {
              "opacity": 0.0,
              "scale": 0.5
            },
            "duration": 0.8
          },
          "50%": {
            "type": "spring",
            "value": {
              "opacity": 1.0,
              "scale": 1.5
            },
            "duration": 0.5,
            "response": 0.4,
            "dampingRatio": 0.6
          },
          "100%": {
            "type": "cubic",
            "value": {
              "opacity": 0.5,
              "scale": 1.0
            },
            "duration": 0.6,
            "startVelocity": 0.2,
            "endVelocity": 0.4
          }
        }
      }
    }
  ]
}