        {
          "type": "Button",
          "id": 7,
          "properties": {
            "title": "Run Action",
            "actionID": "action.run",
            "keyboardShortcut": {
              "key": "R",
              "modifiers": ["command", "shift"]
            }
          }
        }
      ]
    },
    {
      "type": "CommandGroup",
      "id": 8,
      "properties": {
        "placement": "after",
        "placementTarget": "appInfo"
      },
      "children": [
        {
          "type": "Button",
          "id": 9,
          "properties": {
            "title": "About ActionUI Module",
            "actionID": "action.about"
          }
        }
      ]
