{
  "type": "VStack",
  "properties": {
    "spacing": 10.0,
    "alignment": "center",
    "padding": "default"
  },
  "children": [
    {
      "type": "Text",
      "properties": {
        "text": "Picker Variants"
      }
    },
    {
      "type": "Picker",
      "properties": {
        "title": "Select Option",
        "options": [
          "Option1",
          "Option2"
        ],
        "pickerStyle": "menu",
        "actionID": "picker.selection"
      }
    },
    {
      "type": "Picker",
      "properties": {
        "title": "Choose",
        "options": [
          "A",
          "B"
        ],
        "pickerStyle": "segmented",
        "actionID": "picker.selection"
      }
    },
    {
      "type": "Picker",
      "properties": {
        "title": "Radio Group",
        "options": [
          "Red",
          "Green",
          "Blue"
        ],
        "pickerStyle": "radioGroup"
      }
    },
    {
      "type": "Picker",
      "properties": {
        "title": "Horizontal Radio",
        "options": [
          "Small",
          "Medium",
          "Large"
        ],
        "pickerStyle": "radioGroup",
        "horizontalRadioGroupLayout": true
      }
    }
  ]
}
