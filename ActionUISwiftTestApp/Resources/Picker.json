{
  "type": "VStack",
  "properties": {
    "spacing": 10.0,
    "alignment": "center",
    "padding": "default"
  },
  "children": [
    {
      "type": "Text",
      "properties": {
        "text": "Picker Variants"
      }
    },
    {
      "type": "Picker",
      "properties": {
        "title": "Select Option",
        "options": [
          "Option1",
          "Option2"
        ],
        "pickerStyle": "menu",
        "actionID": "picker.selection"
      }
    },
    {
      "type": "Picker",
      "properties": {
        "title": "Choose",
        "options": [
          "A",
          "B"
        ],
        "pickerStyle": "segmented",
        "actionID": "picker.selection"
      }
    },
    {
      "type": "Picker",
      "properties": {
        "title": "Radio Group",
        "options": [
          "Red",
          "Green",
          "Blue"
        ],
        "pickerStyle": "radioGroup",
        "actionID": "picker.radio.selection"
      }
    },
    {
      "type": "Picker",
      "properties": {
        "title": "Horizontal Radio",
        "options": [
          "Small",
          "Medium",
          "Large"
        ],
        "pickerStyle": "radioGroup",
        "horizontalRadioGroupLayout": true,
        "actionID": "picker.radio.horizontal.selection"
      }
    },
    {
      "type": "Text",
      "properties": {
        "text": "Menu Picker — with sections and dividers",
        "font": "headline",
        "padding": { "top": 16, "bottom": 4 }
      }
    },
    {
      "type": "HStack",
      "properties": { "spacing": 16 },
      "children": [
        {
          "type": "Picker",
          "properties": {
            "title": "Sections",
            "options": [
              {"section": "Popular"},
              {"title": "HTML", "tag": "html"},
              {"title": "RTF", "tag": "rtf"},
              {"section": "Other"},
              {"title": "EPUB", "tag": "epub"},
              {"title": "LaTeX", "tag": "latex"}
            ],
            "pickerStyle": "menu",
            "actionID": "picker.selection"
          }
        },
        {
          "type": "Picker",
          "properties": {
            "title": "Divider",
            "options": [
              {"title": "HTML", "tag": "html"},
              {"title": "RTF", "tag": "rtf"},
              {"divider": true},
              {"title": "EPUB", "tag": "epub"},
              {"title": "LaTeX", "tag": "latex"}
            ],
            "pickerStyle": "menu",
            "actionID": "picker.selection"
          }
        }
      ]
    },
    {
      "type": "Text",
      "properties": {
        "text": "Menu Picker — controlSize variants",
        "font": "headline",
        "padding": { "top": 16, "bottom": 4 }
      }
    },
    {
      "type": "Picker",
      "properties": {
        "title": "Mini",
        "options": ["One", "Two", "Three"],
        "pickerStyle": "menu",
        "controlSize": "mini"
      }
    },
    {
      "type": "Picker",
      "properties": {
        "title": "Small",
        "options": ["One", "Two", "Three"],
        "pickerStyle": "menu",
        "controlSize": "small"
      }
    },
    {
      "type": "Picker",
      "properties": {
        "title": "Regular",
        "options": ["One", "Two", "Three"],
        "pickerStyle": "menu",
        "controlSize": "regular"
      }
    },
    {
      "type": "Picker",
      "properties": {
        "title": "Large",
        "options": ["One", "Two", "Three"],
        "pickerStyle": "menu",
        "controlSize": "large"
      }
    },
    {
      "type": "Picker",
      "properties": {
        "title": "Extra Large",
        "options": ["One", "Two", "Three"],
        "pickerStyle": "menu",
        "controlSize": "extraLarge"
      }
    }
  ]
}
