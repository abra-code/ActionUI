{
  "type": "WindowGroup",
  "id": 1,
  "properties": {
    "title": "Default Window",
    "windowGroupID": "WelcomeWindow"
  },
  "content": {
      "type": "VStack",
      "properties": {
          "spacing": 10.0,
          "alignment": "center",
          "background": "gray",
          "frame": {
              "minWidth": 400.0,
              "minHeight": 300.0,
              "idealWidth": 800.0,
              "idealHeight": 600.0
          }
      },
      "children": [
        {
          "type": "Text",
          "properties": {
            "text": "Hello, ActionUI!"
          },
          "id": 2
        },
        {
          "type": "Button",
          "properties": {
            "title": "Action!",
            "buttonStyle": "borderedProminent",
            "actionID": "action.handle"
          },
          "id": 3
        }
      ]
    }
,
  "commands": [
    {
      "type": "CommandMenu",
      "id": 4,
      "properties": {
        "name": "ActionUI"
      },
      "children": [
        {
          "type": "Button",
          "id": 5,
          "properties": {
            "title": "New Action",
            "actionID": "action.new",
            "keyboardShortcut": {
              "key": "N",
              "modifiers": ["command", "shift"]
            }
          }
        },
        {
          "type": "Divider",
          "id": 6
        },
        {
          "type": "Button",
          "id": 7,
          "properties": {
            "title": "Run Action",
            "actionID": "action.run",
            "keyboardShortcut": {
              "key": "R",
              "modifiers": ["command", "shift"]
            }
          }
        }
      ]
    },
    {
      "type": "CommandGroup",
      "id": 8,
      "properties": {
        "placement": "after",
        "placementTarget": "appInfo"
      },
      "children": [
        {
          "type": "Button",
          "id": 9,
          "properties": {
            "title": "About ActionUI Module",
            "actionID": "action.about"
          }
        }
      ]
    }
  ]
}
